# 六、把所有东西连起来

```python
# main.py

import asyncio
from bus.event_bus import EventBus
from agents.planner import planner_handler
from agents.search import search_handler
from agents.summarizer import summarizer_handler
from agents.report import report_handler

bus = EventBus()

# 注册事件
bus.subscribe("user.query", lambda e: planner_handler(e, bus))
bus.subscribe("plan.created", lambda e: search_handler(e, bus))
bus.subscribe("search.completed", lambda e: summarizer_handler(e, bus))
bus.subscribe("summary.completed", lambda e: report_handler(e, bus))

async def main():
    await bus.publish({
        "type": "user.query",
        "payload": {"query": "Analyze OpenAI models"}
    })

asyncio.run(main())
```

