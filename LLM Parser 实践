# ====================== 1. OpenAPI → 动态 Pydantic Model 转换器 ======================
def json_schema_to_pydantic_model(
    schema: Dict[str, Any], model_name: str = "DynamicInputModel"
) -> Type[BaseModel]:
    """递归将 OpenAPI JSON Schema 转为 Pydantic Model（支持嵌套 object/array）"""
    if not schema or schema.get("type") != "object":
        return create_model(model_name, __base__=BaseModel)

    properties = schema.get("properties", {})
    required = set(schema.get("required", []))

    fields: Dict[str, Any] = {}
    for prop_name, prop_schema in properties.items():
        json_type = prop_schema.get("type")
        description = prop_schema.get("description", "")

        # 类型映射
        if json_type == "string":
            field_type = str
        elif json_type == "integer":
            field_type = int
        elif json_type == "number":
            field_type = float
        elif json_type == "boolean":
            field_type = bool
        elif json_type == "array":
            items_schema = prop_schema.get("items", {})
            item_model = json_schema_to_pydantic_model(items_schema, prop_name.capitalize() + "Item")
            field_type = List[item_model]
        elif json_type == "object":
            nested_model = json_schema_to_pydantic_model(prop_schema, prop_name.capitalize() + "Model")
            field_type = nested_model
        else:
            field_type = Any

        field_info = Field(
            default=... if prop_name in required else None,
            description=description
        )
        fields[prop_name] = (field_type, field_info)

    return create_model(model_name, **fields, __base__=BaseModel)


def create_tool_from_openapi_operation(
    spec: Dict[str, Any],
    path: str,
    method: str,
    operation: Dict[str, Any],
    base_url: str,
) -> StructuredTool:
    """为单个 OpenAPI Operation 动态创建 StructuredTool + Pydantic Model"""
    operation_id = operation.get("operationId") or f"{method}_{path.replace('/', '_')}"
    summary = operation.get("summary", "")
    description = operation.get("description", summary)

    # 1. 处理 parameters（query/path/header）
    parameters = operation.get("parameters", [])
    param_fields: Dict[str, Any] = {}
    for param in parameters:
        p_name = param["name"]
        p_schema = param.get("schema", {})
        p_type = p_schema.get("type", "string")
        field_type = str if p_type == "string" else int if p_type == "integer" else Any
        param_fields[p_name] = (
            field_type,
            Field(default=None, description=param.get("description", ""))
        )

    # 2. 处理 requestBody（JSON）
    request_body = operation.get("requestBody", {}).get("content", {}).get("application/json", {})
    body_schema = request_body.get("schema", {})
    if body_schema:
        BodyModel = json_schema_to_pydantic_model(body_schema, f"{operation_id}Body")
        param_fields["body"] = (BodyModel, Field(default=None, description="请求体"))

    # 3. 创建完整的输入 Pydantic Model
    InputModel = create_model(
        f"{operation_id}Input",
        **param_fields,
        __base__=BaseModel
    )

    # 4. 真实的 API 执行函数（可自行替换为你的认证/SDK）
    def execute_api(input_data: InputModel) -> str:
        """真实调用 API"""
        url = f"{base_url.rstrip('/')}{path}"
        headers = {"Content-Type": "application/json"}  # ← 这里可加你的 Auth

        # 处理 path/query 参数
        params = {}
        path_url = url
        data = None

        input_dict = input_data.model_dump(exclude_unset=True)
        if "body" in input_dict:
            data = input_dict.pop("body")
            if isinstance(data, BaseModel):
                data = data.model_dump()

        for p_name, value in list(input_dict.items()):
            # 简单 path 替换（实际生产建议用 urllib.parse）
            if f"{{{p_name}}}" in path_url:
                path_url = path_url.replace(f"{{{p_name}}}", str(value))
            else:
                params[p_name] = value

        try:
            response = requests.request(
                method=method.upper(),
                url=path_url,
                params=params,
                json=data,
                headers=headers,
                timeout=30
            )
            response.raise_for_status()
            return f"✅ API 调用成功 [{response.status_code}]:\n{response.text[:500]}..."
        except Exception as e:
            return f"❌ API 调用失败: {str(e)}"

    # 5. 创建 LangChain StructuredTool
    tool = StructuredTool.from_function(
        func=execute_api,
        name=operation_id,
        description=f"{summary}\n\n{description}\n\nEndpoint: {method.upper()} {path}",
        args_schema=InputModel,
        return_direct=False,
    )

    # 额外元数据（用于向量搜索和文档）
    tool.metadata = {
        "name": operation_id,
        "description": description,
        "summary": summary,
        "method": method,
        "path": path,
        "base_url": base_url,
        "example_nl_calls": [  # 自然语言调用示例（模板，可后续用 LLM 优化）
            f"帮我调用 {summary}",
            f"使用 {operation_id} 接口，参数是...",
            f"执行 {path} 接口",
        ]
    }
    return tool


# ====================== 2. 加载所有 OpenAPI Spec 并生成工具 ======================
def load_all_tools_from_openapi_specs() -> List[StructuredTool]:
    """从目录加载 700+ OpenAPI Spec，动态生成所有工具"""
    all_tools: List[StructuredTool] = []
    spec_files = list(OPENAPI_SPECS_DIR.glob("*.json"))

    print(f"找到 {len(spec_files)} 个 OpenAPI Spec 文件，开始动态生成 Pydantic Model 和 Tools...")

    for spec_file in spec_files:
        with open(spec_file, "r", encoding="utf-8") as f:
            spec = json.load(f)

        base_url = spec.get("servers", [{}])[0].get("url", "https://api.example.com")
        paths = spec.get("paths", {})

        for path, methods in paths.items():
            for method, operation in methods.items():
                if method.lower() in ["get", "post", "put", "delete", "patch"]:
                    tool = create_tool_from_openapi_operation(
                        spec=spec,
                        path=path,
                        method=method,
                        operation=operation,
                        base_url=base_url
                    )
                    all_tools.append(tool)

    print(f"✅ 成功生成 {len(all_tools)} 个工具（来自 {len(spec_files)} 个 Spec）")
    return all_tools


# ====================== 3. PGVector 向量库（语义搜索） ======================
embeddings = OpenAIEmbeddings(model="text-embedding-3-small")

ALL_TOOLS = load_all_tools_from_openapi_specs()          # ← 这里一次性生成 700+ 工具
TOOL_DICT = {t.name: t for t in ALL_TOOLS}

# 构建向量文档（只执行一次）
tool_docs = []
for t in ALL_TOOLS:
    meta = t.metadata
    doc = Document(
        page_content=f"""Tool: {meta['name']}
描述: {meta['description']}
总结: {meta.get('summary', '')}
Endpoint: {meta.get('method', '')} {meta.get('path', '')}
自然语言调用示例:
{chr(10).join(meta.get('example_nl_calls', []))}""",
        metadata={
            "name": meta["name"],
            "description": meta["description"],
            "type": "action"   # 所有工具默认都是 action
        }
    )
    tool_docs.append(doc)

vectorstore = PGVector(
    connection_string=PG_CONNECTION_STRING,
    collection_name="tool_search_700_openapi",
    embeddings=embeddings,
)

if len(vectorstore.get()["ids"]) == 0:
    print("正在为 700+ 工具创建 PGVector 索引（只需执行一次）...")
    vectorstore.add_documents(tool_docs)
    print("✅ PGVector 索引创建完成")

retriever = vectorstore.as_retriever(search_kwargs={"k": 5})

# ====================== 4. Tool Search Tool（动态发现） ======================
@tool
def tool_search(query: str) -> str:
    """搜索可用 API。输入自然语言，返回最匹配的工具并自动加载。"""
    docs = retriever.invoke(query)
    matched_names = [doc.metadata["name"] for doc in docs]
    details = "\n".join([f"• {doc.metadata['name']}: {doc.metadata['description']}" for doc in docs])
    return json.dumps({
        "matched_tools": matched_names,
        "message": f"✅ 已找到并加载以下 API（下次可直接调用）：{', '.join(matched_names)}",
        "details": details
    }, ensure_ascii=False)

# ====================== 5. 文档解释工具（info_query 专用） ======================
@tool
def get_tool_documentation(tool_name: str) -> str:
    """用户只想了解 API 如何使用时调用，返回完整描述 + 自然语言调用示例"""
    tool = TOOL_DICT.get(tool_name)
    if not tool:
        return "❌ 未找到该 API"
    meta = tool.metadata
    examples = "\n".join([f"• {ex}" for ex in meta.get("example_nl_calls", [])])
    return f"""
🔍 API 名称：{meta['name']}
📝 描述：{meta['description']}

🌐 Endpoint: {meta.get('method', '')} {meta.get('path', '')}

💡 自然语言调用示例（直接复制给机器人即可）：
{examples}

✅ 你现在可以直接用上面任意一句话调用这个 API。
"""


# ====================== 6. Intent 分类器（结构化输出） ======================
class IntentOutput(BaseModel):
    intent: str = Field(..., description="只能是 'action'（执行API）或 'info_query'（只问用法）")
    target_tool_names: List[str] = Field(default_factory=list, description="可能匹配的工具名")
    query_summary: str = Field(..., description="用户意图一句话总结")

classify_llm = ChatOpenAI(model="gpt-4o-mini", temperature=0).with_structured_output(IntentOutput)

@tool
def classify_intent(user_query: str) -> str:
    """第一步：判断用户是想执行 API 还是只询问用法"""
    result = classify_llm.invoke(f"""
用户查询：{user_query}

请严格判断：
- 如果用户想要实际调用/执行某个 API → intent = "action"
- 如果用户只问“这个 API 怎么用”“参数是什么”“示例” → intent = "info_query"
""")
    return result.model_dump_json()


# ====================== 7. LangGraph 核心状态与动态加载 ======================
class ParserState(MessagesState):
    loaded_tools: List[str] = []
    intent_result: Dict | None = None

BASE_TOOLS = [classify_intent, tool_search, get_tool_documentation]

llm = ChatOpenAI(model="gpt-4o", temperature=0)

def dynamic_tools_middleware(state: ParserState, model: ChatOpenAI):
    """动态绑定工具（核心！）"""
    current_tools = BASE_TOOLS.copy()
    for name in state.get("loaded_tools", []):
        if name in TOOL_DICT:
            current_tools.append(TOOL_DICT[name])
    return model.bind_tools(current_tools)


def agent_node(state: ParserState):
    model_with_tools = dynamic_tools_middleware(state, llm)
    system_prompt = SystemMessage(content="""
你是一个专业的 OpenAPI Parser Agent。
规则：
1. 先调用 classify_intent 判断用户意图。
2. 如果是 info_query → 调用 get_tool_documentation。
3. 如果是 action 但工具未加载 → 先调用 tool_search 搜索。
4. 加载成功后直接调用对应 API。
保持简洁，只输出必要信息。
""")
    response = model_with_tools.invoke([system_prompt] + state["messages"])
    return {"messages": [response]}


def update_loaded_tools(state: ParserState) -> ParserState:
    """tool_search 执行后自动加载工具"""
    loaded = state.get("loaded_tools", []).copy()
    for msg in reversed(state["messages"]):
        if isinstance(msg, dict) and msg.get("name") == "tool_search":
            try:
                data = json.loads(msg.get("content", "{}"))
                for m in data.get("matched_tools", []):
                    if m not in loaded:
                        loaded.append(m)
            except:
                pass
            break
    state["loaded_tools"] = loaded
    return state


# ====================== 8. 构建 LangGraph 工作流 ======================
workflow = StateGraph(ParserState)

workflow.add_node("agent", agent_node)
workflow.add_node("tools", ToolNode(tools=ALL_TOOLS + BASE_TOOLS))
workflow.add_node("update_loaded_tools", update_loaded_tools)

def should_continue(state: ParserState):
    last_msg = state["messages"][-1]
    if hasattr(last_msg, "tool_calls") and last_msg.tool_calls:
        return "tools"
    return "__end__"

workflow.add_conditional_edges("agent", should_continue, {"tools": "tools", "__end__": "__end__"})
workflow.add_edge("tools", "update_loaded_tools")
workflow.add_edge("update_loaded_tools", "agent")
workflow.set_entry_point("agent")

checkpointer = InMemorySaver()
parser_agent = workflow.compile(checkpointer=checkpointer)

