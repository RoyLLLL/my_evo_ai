from google.adk.agents import BaseAgent
from google.adk.agents.invocation_context import InvocationContext
from google.adk.events import Event
from google.genai.types import Content, Part

from typing import AsyncGenerator, List, Optional
import os

from src.schemas.a2a_types import AgentCard
from src.utils.a2a_enhanced_client import (
    EnhancedA2AClient,
    A2AClientConfig,
    A2AImplementation,
    A2AResponse,
)

from uuid import uuid4


class A2ACustomAgent(BaseAgent):

    agent_card_url: str
    agent_card: Optional[AgentCard]
    timeout: int
    base_url: str
    api_key: Optional[str]
    preferred_implementation: A2AImplementation

    # NEW
    output_key: str
    debug: bool

    def __init__(
        self,
        name: str,
        agent_card_url: str,
        timeout: int = 300,
        api_key: Optional[str] = None,
        preferred_implementation: A2AImplementation = A2AImplementation.AUTO,
        sub_agents: List[BaseAgent] = [],
        output_key: str = "remote_agent_result",
        debug: bool = False,
        **kwargs,
    ):

        base_url = agent_card_url

        if "/.well-known/agent.json" in base_url:
            base_url = base_url.split("/.well-known/agent.json")[0]

        if "/api/v1/a2a/" in base_url:
            base_url = base_url.split("/api/v1/a2a/")[0]

        elif "/api/v1/a2a-sdk/" in base_url:
            base_url = base_url.split("/api/v1/a2a-sdk/")[0]

        if not api_key:
            api_key = os.getenv("EVO_AI_API_KEY") or os.getenv("API_KEY")

        super().__init__(
            name=name,
            agent_card_url=agent_card_url,
            base_url=base_url,
            agent_card=None,
            timeout=timeout,
            api_key=api_key,
            preferred_implementation=preferred_implementation,
            sub_agents=sub_agents,
            output_key=output_key,
            debug=debug,
            **kwargs,
        )

    async def fetch_agent_card(self) -> AgentCard:

        if self.agent_card:
            return self.agent_card

        agent_id = self._extract_agent_id_from_url(self.agent_card_url)

        config = A2AClientConfig(
            base_url=self.base_url,
            api_key=self.api_key or "default-key",
            implementation=self.preferred_implementation,
            timeout=self.timeout,
        )

        async with EnhancedA2AClient(config) as client:

            response = await client.get_agent_card(agent_id)

            if response.success:

                self.agent_card = AgentCard(**response.data)

                return self.agent_card

        # fallback card
        self.agent_card = AgentCard(
            name="A2A Agent",
            description="External A2A Agent",
            url=self.agent_card_url,
            version="1.0.0",
            capabilities={"streaming": True},
            defaultInputModes=["text"],
            defaultOutputModes=["text"],
            skills=[],
        )

        return self.agent_card

    def _extract_agent_id_from_url(self, url: str) -> str:

        if "/api/v1/a2a/" in url:

            return url.split("/api/v1/a2a/")[1].split("/")[0]

        if "/api/v1/a2a-sdk/" in url:

            return url.split("/api/v1/a2a-sdk/")[1].split("/")[0]

        return "unknown-agent"

    async def _run_async_impl(
        self, ctx: InvocationContext
    ) -> AsyncGenerator[Event, None]:

        aggregated_text = ""

        try:

            agent_card = await self.fetch_agent_card()

            user_message = self._extract_user_message(ctx)

            if not user_message:

                yield Event(
                    author=self.name,
                    content=Content(
                        role="agent",
                        parts=[Part(text="No user message found")],
                    ),
                )

                return

            agent_id = self._extract_agent_id_from_url(self.agent_card_url)

            config = A2AClientConfig(
                base_url=self.base_url,
                api_key=self.api_key or "default-key",
                implementation=self.preferred_implementation,
                timeout=self.timeout,
            )

            async with EnhancedA2AClient(config) as client:

                session_id = (
                    str(ctx.session.id)
                    if ctx.session and hasattr(ctx.session, "id")
                    else str(uuid4())
                )

                supports_streaming = self._agent_supports_streaming(agent_card)

                if supports_streaming:

                    async for event in self._process_streaming_response(
                        client,
                        agent_id,
                        user_message,
                        session_id,
                    ):

                        text = self._extract_text_from_event(event)

                        if text:
                            aggregated_text += text + "\n"

                        yield event

                else:

                    async for event in self._process_regular_response(
                        client,
                        agent_id,
                        user_message,
                        session_id,
                    ):

                        text = self._extract_text_from_event(event)

                        if text:
                            aggregated_text += text + "\n"

                        yield event

            # =========================
            # 写入 shared state
            # =========================

            if aggregated_text.strip():

                key = self.output_key or "remote_agent_result"

                if ctx.session:

                    if ctx.session.state is None:

                        ctx.session.state = {}

                    ctx.session.state[key] = aggregated_text.strip()

                # 写入 conversation history
                yield Event(
                    author=self.name,
                    content=Content(
                        role="agent",
                        parts=[Part(text=aggregated_text.strip())],
                    ),
                )

                if self.debug:

                    print("\n[A2A RESULT SAVED]")
                    print("key =", key)
                    print(aggregated_text)

            # =========================
            # 执行 sub agents
            # =========================

            for sub_agent in self.sub_agents:

                async for event in sub_agent.run_async(ctx):

                    yield event

        except Exception as e:

            yield Event(
                author=self.name,
                content=Content(
                    role="agent",
                    parts=[Part(text=str(e))],
                ),
            )

    def _extract_user_message(self, ctx: InvocationContext) -> Optional[str]:

        if ctx.session and ctx.session.events:

            for event in reversed(ctx.session.events):

                if event.author == "user":

                    if event.content and event.content.parts:

                        return event.content.parts[0].text

        return None

    def _agent_supports_streaming(self, agent_card: AgentCard) -> bool:

        try:

            if hasattr(agent_card, "capabilities"):

                if isinstance(agent_card.capabilities, dict):

                    return agent_card.capabilities.get("streaming", False)

                return getattr(agent_card.capabilities, "streaming", False)

        except:

            pass

        return False

    async def _process_streaming_response(

        self,

        client: EnhancedA2AClient,

        agent_id: str,

        message: str,

        session_id: str,

    ) -> AsyncGenerator[Event, None]:

        async for response_chunk in client.send_message_streaming(

            agent_id=agent_id,

            message=message,

            session_id=session_id,

        ):

            if response_chunk.success:

                event = self._create_event_from_response(response_chunk)

                if event:

                    yield event

            else:

                yield Event(

                    author=self.name,

                    content=Content(

                        role="agent",

                        parts=[Part(text=response_chunk.error)],

                    ),

                )

    async def _process_regular_response(

        self,

        client: EnhancedA2AClient,

        agent_id: str,

        message: str,

        session_id: str,

    ) -> AsyncGenerator[Event, None]:

        response = await client.send_message(

            agent_id=agent_id,

            message=message,

            session_id=session_id,

        )

        if response.success:

            event = self._create_event_from_response(response)

            if event:

                yield event

        else:

            yield Event(

                author=self.name,

                content=Content(

                    role="agent",

                    parts=[Part(text=response.error)],

                ),

            )

    def _create_event_from_response(

        self,

        response: A2AResponse,

    ) -> Optional[Event]:

        try:

            data = response.data

            parts = []

            if isinstance(data, dict):

                if "result" in data:

                    result = data["result"]

                    if isinstance(result, dict):

                        status = result.get("status")

                        if status:

                            message = status.get("message")

                            if message:

                                for p in message.get("parts", []):

                                    if p.get("type") == "text":

                                        parts.append(

                                            Part(text=p.get("text", ""))

                                        )

            if parts:

                return Event(

                    author=self.name,

                    content=Content(

                        role="agent",

                        parts=parts,

                    ),

                )

        except Exception as e:

            return Event(

                author=self.name,

                content=Content(

                    role="agent",

                    parts=[Part(text=str(e))],

                ),

            )

        return None

    def _extract_text_from_event(self, event: Event) -> str:

        try:

            texts = []

            if event.content:

                for p in event.content.parts:

                    if hasattr(p, "text"):

                        texts.append(p.text)

            return "\n".join(texts)

        except:

            return ""
