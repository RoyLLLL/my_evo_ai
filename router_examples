七、Vector Retrieval

vector_store.py

import faiss
import numpy as np
from .tool_registry import tool_registry
from .config import TOP_K_TOOLS

def embed(text):

    np.random.seed(abs(hash(text)) % 100000)

    return np.random.rand(768).astype("float32")

embeddings = np.array([
embed(t["name"] + t["description"])
for t in tool_registry
])

index = faiss.IndexFlatL2(768)

index.add(embeddings)

def retrieve_tools(query):

    q = embed(query).reshape(1,-1)

    D,I = index.search(q, TOP_K_TOOLS)

    return [tool_registry[i] for i in I[0]]
