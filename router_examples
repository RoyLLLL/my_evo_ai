九、Query Classifier

classifier.py

from openai import AzureOpenAI
from .config import AZURE_ENDPOINT, AZURE_MODEL

client = AzureOpenAI(
    azure_endpoint=AZURE_ENDPOINT,
    api_version="2024-02-15-preview"
)

async def classify_query(query):

    prompt = """
Decide if the user is asking about product features.

Return only:

helper
tool
"""

    r = client.chat.completions.create(
        model=AZURE_MODEL,
        messages=[
            {"role":"system","content":prompt},
            {"role":"user","content":query}
        ]
    )

    label = r.choices[0].message.content.strip().lower()

    if "helper" in label:
        return "helper"

    return "tool"
十、Tool Planner（Instructor）

planner.py

import instructor
import json
from pydantic import BaseModel
from typing import List, Dict, Any
from openai import AzureOpenAI
from .config import AZURE_ENDPOINT, AZURE_MODEL

class ToolCall(BaseModel):

    tool_name:str
    arguments:Dict[str,Any]

class ToolPlan(BaseModel):

    steps:List[ToolCall]

client = instructor.from_openai(

AzureOpenAI(
azure_endpoint=AZURE_ENDPOINT,
api_version="2024-02-15-preview"
)
)

def plan_tools(query,history,tools):

    tool_text=""

    for t in tools:

        tool_text+=f"""
Tool:{t['name']}
Description:{t['description']}
Schema:{json.dumps(t['input_schema'])}
"""

    prompt=f"""
You are a tool planner.

Available tools:

{tool_text}

Return JSON:

{{"steps":[{{"tool_name":"","arguments":{{}}}}]}}
"""

    messages=[{"role":"system","content":prompt}]

    messages+=history

    messages.append({"role":"user","content":query})

    return client.chat.completions.create(
        model=AZURE_MODEL,
        response_model=ToolPlan,
        messages=messages
)
十一、Dispatcher（带 retry）

dispatcher.py

import httpx
from .config import DOWNSTREAM_API

async def dispatch(userid, tool, params):

    async with httpx.AsyncClient() as client:

        r = await client.post(
            DOWNSTREAM_API,
            json={
                "userid":userid,
                "tool_name":tool,
                "parameters":params
            }
        )

    return r.json()


async def dispatch_with_retry(userid, tool, params):

    for i in range(2):

        try:

            return await dispatch(userid,tool,params)

        except Exception:

            if i==1:
                return {"error":"tool_failed","tool":tool}
十二、LangGraph Graph

graph.py

import asyncio

from typing import TypedDict, List, Dict, Any

from langgraph.graph import StateGraph, END

from .classifier import classify_query
from .vector_store import retrieve_tools
from .planner import plan_tools
from .dispatcher import dispatch_with_retry
from .helper_tool import helper_tool


class AgentState(TypedDict):

    userid:str
    session_id:str
    query:str

    history:List[Dict]

    route:str

    tools:List[Dict]

    tool_plan:Dict

    results:List[Any]


async def classifier_node(state):

    route = await classify_query(state["query"])

    return {"route":route}


async def helper_node(state):

    r = await helper_tool(state["query"])

    return {"results":[r]}


async def retrieve_node(state):

    tools = retrieve_tools(state["query"])

    return {"tools":tools}


async def planner_node(state):

    plan = plan_tools(
        state["query"],
        state["history"],
        state["tools"]
    )

    return {"tool_plan":plan.dict()}


async def executor_node(state):

    steps = state["tool_plan"]["steps"]

    tasks=[]

    for s in steps:

        tasks.append(
            dispatch_with_retry(
                state["userid"],
                s["tool_name"],
                s["arguments"]
            )
        )

    results = await asyncio.gather(*tasks)

    return {"results":results}


def route_decision(state):

    if state["route"]=="helper":
        return "helper"

    return "retrieve"


graph = StateGraph(AgentState)

graph.add_node("classifier", classifier_node)

graph.add_node("helper", helper_node)

graph.add_node("retrieve", retrieve_node)

graph.add_node("planner", planner_node)

graph.add_node("executor", executor_node)

graph.set_entry_point("classifier")

graph.add_conditional_edges(
    "classifier",
    route_decision,
    {
        "helper":"helper",
        "tool":"retrieve"
    }
)

graph.add_edge("helper", END)

graph.add_edge("retrieve","planner")

graph.add_edge("planner","executor")

graph.add_edge("executor",END)

agent_graph = graph.compile()
十三、Streaming API

api_stream.py

import json

from fastapi import APIRouter
from fastapi.responses import StreamingResponse
from pydantic import BaseModel

from .graph import agent_graph
from .history_repository import load_recent_history, save_message


router = APIRouter()


class ToolRequest(BaseModel):

    userid:str
    session_id:str
    query:str


async def stream_pipeline(req):

    history = load_recent_history(req.session_id)

    state = {

    "userid":req.userid,
    "session_id":req.session_id,
    "query":req.query,
    "history":history

}

    async for event in agent_graph.astream(state):

        yield json.dumps(event)+"\n"

    save_message(req.session_id,"user",req.query)


@router.post("/tool_router/stream")

async def tool_stream(req:ToolRequest):

    return StreamingResponse(
        stream_pipeline(req),
        media_type="text/event-stream"
)
